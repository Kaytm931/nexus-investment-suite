      "terminal_growth": 0.02,
      "notes": "Banks don't have traditional free cashflow. Use excess returns or dividend discount. CET1 > 12% is strong."
    },
    "red_flags": {
      "npl_ratio_above": 0.05,
      "cet1_below": 0.10,
      "roe_below": 0.08,

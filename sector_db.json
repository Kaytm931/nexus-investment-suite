{
  "Insurance": {
    "display_name": "Insurance",
    "sector_type": "Financials",
    "metrics": {
      "valuation": ["P/EV", "P/Book", "P/E_TTM"],
      "quality": ["Combined_Ratio", "Loss_Ratio", "ROE", "Investment_Yield"],
      "growth": ["Premium_Growth", "EPS_Growth"],
      "risk": ["Solvency_II_Ratio", "Debt_to_Equity", "Beta"]
    },
    "dcf_inputs": {
      "primary_cashflow": "operating_cashflow",
      "preferred_method": "P/EV + Dividend Discount Model",
      "discount_rate": 0.09,
      "terminal_growth": 0.025,
      "notes": "Use P/Embedded Value for life insurers. Combined ratio <95% is excellent."
    },
    "red_flags": {
      "combined_ratio_above": 105,
      "solvency_ratio_below": 150,
      "debt_to_equity_above": 0.5,
      "roe_below": 0.08
    },
    "geopolitical_risks": [
      "Climate change increasing catastrophe claims",
      "Regulatory changes (Solvency II, IFRS 17)",
      "Low interest rate environment compressing investment income",
      "Cyber risk accumulation"
    ],
    "scoring_weights": {
      "valuation": 0.30,
      "quality": 0.30,
      "risk": 0.25,
      "growth": 0.15
    }
  },
  "Banking": {

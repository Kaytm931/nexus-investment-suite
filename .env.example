# ── Supabase ────────────────────────────────────────────────────────────────
# Get these from: https://app.supabase.com → Project Settings → API
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here  # Backend only, never expose to frontend

# ── Encryption ──────────────────────────────────────────────────────────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your_fernet_encryption_key_here

# ── Tavily (web search for AI analysis) ─────────────────────────────────────
# Get free key at: https://tavily.com
TAVILY_API_KEY=tvly-your-key-here

# ── Alpha Vantage (optional, fallback data) ──────────────────────────────────
# Get free key at: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_KEY=your_av_key_here

# ── Ollama (local LLM) ───────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma3:27b

# ── App Settings ─────────────────────────────────────────────────────────────
PORT=7842
FRONTEND_URL=http://localhost:5173   # Vite dev server

# ── Frontend (.env.local in frontend-react/) ─────────────────────────────────
# Copy these to frontend-react/.env.local
# VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
# VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
# VITE_API_BASE=http://localhost:7842          # local dev
# VITE_API_BASE=https://nexus-backend.onrender.com  # production (after Render deploy)
